---
import Layout from '../../layouts/Layout.astro'
import { getCollection, render } from 'astro:content'

export const prerender = true

export async function getStaticPaths() {
  const posts = await getCollection('blog')
  return posts.map((post) => {
    // Remove .md extension for slug
    const slug = post.id.replace(/\.md$/, '')
    return {
      params: { slug },
      props: { post },
    }
  })
}

const { post } = Astro.props
const { Content } = await render(post)

function getCategory(id: string): string {
  const parts = id.split('/')
  return parts.length > 1 ? parts[0] : 'thoughts'
}

const category = getCategory(post.id)
const categoryLabels: Record<string, string> = {
  hike: 'trip reports',
  gear: 'gear',
  thoughts: 'thoughts',
}

function formatDate(dateStr: string) {
  const date = new Date(dateStr)
  return date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })
}

// Build prev/next navigation
const allPosts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
)
const currentIndex = allPosts.findIndex((p) => p.id === post.id)
const prevPost = currentIndex > 0 ? allPosts[currentIndex - 1] : null
const nextPost = currentIndex < allPosts.length - 1 ? allPosts[currentIndex + 1] : null

// Extract headers for table of contents
const slug = post.id.replace(/\.md$/, '')
---

<Layout 
  title={post.data.title} 
  description={`${categoryLabels[category]} - ${post.data.title}`}
  ogImage={`https://kylies.photos/api/og/${slug}`}
  ogImageAlt={post.data.title}
>
  <article class="container blog-post">
    <header class="post-header">
      <a href="/blog" class="back-link">&larr; Back to blog</a>
      <span class={`post-category cat-${category}`}>{categoryLabels[category]}</span>
      <h1>{post.data.title}</h1>
      <time datetime={post.data.date}>{formatDate(post.data.date)}</time>
    </header>

    {post.data.previewImgUrl && (
      <figure class="hero-image">
        <img src={post.data.previewImgUrl} alt={post.data.title} />
      </figure>
    )}

    <div class="post-content-wrapper">
      <div class="post-body prose" id="post-body">
        <Content />
      </div>

      <aside class="toc-sidebar" id="toc-sidebar">
        <nav class="toc-nav" aria-label="Table of contents">
          <h3 class="toc-title">On this page</h3>
          <ul id="toc-list"></ul>
        </nav>
      </aside>
    </div>

    {(prevPost || nextPost) && (
      <nav class="post-navigation" aria-label="Post navigation">
        {prevPost && (
          <a href={`/blog/${prevPost.id.replace(/\.md$/, '')}`} class="nav-link prev">
            <span class="nav-label">← Previous Post</span>
            <span class="nav-title">{prevPost.data.title}</span>
            <span class="nav-category">{categoryLabels[getCategory(prevPost.id)]}</span>
          </a>
        )}
        {nextPost && (
          <a href={`/blog/${nextPost.id.replace(/\.md$/, '')}`} class="nav-link next">
            <span class="nav-label">Next Post →</span>
            <span class="nav-title">{nextPost.data.title}</span>
            <span class="nav-category">{categoryLabels[getCategory(nextPost.id)]}</span>
          </a>
        )}
      </nav>
    )}

    <footer class="post-footer">
      <a href="/blog" class="back-link">&larr; Back to blog</a>
    </footer>
  </article>
</Layout>

<style>
  .blog-post {
    max-width: 800px;
    padding-top: var(--space-xl);
    padding-bottom: var(--space-3xl);
  }

  .post-header {
    margin-bottom: var(--space-xl);
  }

  .back-link {
    display: inline-block;
    font-size: var(--font-size-sm);
    color: var(--color-text-tertiary);
    text-decoration: none;
    margin-bottom: var(--space-lg);
  }

  .back-link:hover {
    color: var(--color-accent);
  }

  .post-category {
    display: block;
    font-size: var(--font-size-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-sm);
  }

  .post-category.cat-hike {
    color: var(--color-purple, #8b5cf6);
  }

  .post-category.cat-gear {
    color: var(--color-orange, #f97316);
  }

  .post-category.cat-thoughts {
    color: var(--color-pink, #ec4899);
  }

  .post-header h1 {
    font-size: 2.5rem;
    line-height: 1.2;
    margin-bottom: var(--space-md);
  }

  .post-header time {
    font-size: var(--font-size-base);
    color: var(--color-text-tertiary);
  }

  .hero-image {
    margin: 0 calc(-1 * var(--space-lg)) var(--space-xl);
    border-radius: var(--border-radius);
    overflow: hidden;
  }

  .hero-image img {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Prose styles for markdown content */
  .prose {
    line-height: 1.75;
    color: var(--color-text-secondary);
  }

  .prose :global(h2) {
    font-size: var(--font-size-xl);
    color: var(--color-text);
    margin-top: var(--space-2xl);
    margin-bottom: var(--space-md);
  }

  .prose :global(h3) {
    font-size: var(--font-size-lg);
    color: var(--color-text);
    margin-top: var(--space-xl);
    margin-bottom: var(--space-sm);
  }

  .prose :global(p) {
    margin-bottom: var(--space-lg);
  }

  .prose :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .prose :global(a:hover) {
    color: var(--color-accent-hover);
  }

  .prose :global(img) {
    width: 100%;
    height: auto;
    border-radius: var(--border-radius);
    margin: var(--space-lg) 0;
  }

  .prose :global(blockquote) {
    border-left: 3px solid var(--color-accent);
    padding-left: var(--space-lg);
    margin: var(--space-lg) 0;
    font-style: italic;
    color: var(--color-text-tertiary);
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin-bottom: var(--space-lg);
    padding-left: var(--space-xl);
  }

  .prose :global(li) {
    margin-bottom: var(--space-sm);
  }

  .prose :global(code) {
    background: var(--color-bg-tertiary);
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    font-size: 0.9em;
  }

  .prose :global(pre) {
    background: var(--color-bg-tertiary);
    padding: var(--space-lg);
    border-radius: var(--border-radius);
    overflow-x: auto;
    margin: var(--space-lg) 0;
  }

  .prose :global(pre code) {
    background: none;
    padding: 0;
  }

  .post-footer {
    margin-top: var(--space-3xl);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--color-border);
  }

  .post-navigation {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
    margin-top: var(--space-3xl);
    margin-bottom: var(--space-xl);
    padding-top: var(--space-xl);
    border-top: 1px solid var(--color-border);
  }

  .nav-link {
    display: flex;
    flex-direction: column;
    padding: var(--space-lg);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius);
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .nav-link:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .nav-link.next {
    text-align: right;
    margin-left: auto;
  }

  .nav-link:only-child {
    grid-column: span 2;
    max-width: 50%;
  }

  .nav-link:only-child.prev {
    margin-right: auto;
    margin-left: 0;
  }

  .nav-link:only-child.next {
    margin-left: auto;
    margin-right: 0;
  }

  .nav-label {
    font-size: var(--font-size-sm);
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-xs);
  }

  .nav-title {
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-xs);
    line-height: 1.3;
  }

  .nav-category {
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-secondary);
  }

  @media (max-width: 640px) {
    .post-navigation {
      grid-template-columns: 1fr;
    }

    .nav-link.next {
      text-align: left;
      margin-left: 0;
    }

    .nav-link:only-child {
      grid-column: span 1;
      max-width: 100%;
    }
  }

  .post-content-wrapper {
    display: grid;
    grid-template-columns: 1fr 240px;
    gap: var(--space-3xl);
    position: relative;
  }

  .toc-sidebar {
    display: none;
  }

  @media (min-width: 1024px) {
    .toc-sidebar {
      display: block;
    }

    .blog-post {
      max-width: 1100px;
    }
  }

  .toc-nav {
    position: sticky;
    top: calc(var(--header-height, 80px) + var(--space-xl));
    max-height: calc(100vh - var(--header-height, 80px) - var(--space-2xl));
    overflow-y: auto;
    padding: var(--space-lg);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--border-radius);
  }

  .toc-title {
    font-size: var(--font-size-sm);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-md);
    margin-top: 0;
  }

  #toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  #toc-list li {
    margin-bottom: var(--space-xs);
  }

  .toc-link {
    display: block;
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    text-decoration: none;
    padding: var(--space-xs) 0;
    border-left: 2px solid transparent;
    padding-left: var(--space-md);
    margin-left: calc(-1 * var(--space-md));
    transition: all 0.2s ease;
    line-height: 1.4;
  }

  .toc-link:hover {
    color: var(--color-accent);
    border-left-color: var(--color-accent);
  }

  .toc-link.active {
    color: var(--color-accent);
    border-left-color: var(--color-accent);
    font-weight: 500;
  }

  @media (max-width: 640px) {
    .post-header h1 {
      font-size: 1.75rem;
    }

    .hero-image {
      margin-left: calc(-1 * var(--space-md));
      margin-right: calc(-1 * var(--space-md));
      border-radius: 0;
    }

    .post-content-wrapper {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // Generate TOC from h2 elements
  const content = document.getElementById('post-body')
  const tocList = document.getElementById('toc-list')
  const tocSidebar = document.getElementById('toc-sidebar')

  if (content && tocList) {
    const headings = Array.from(content.querySelectorAll('h2'))

    // Only show TOC if we have enough headings
    if (headings.length < 2) {
      if (tocSidebar) tocSidebar.style.display = 'none'
    } else {
      headings.forEach((heading) => {
        const id = heading.textContent
          .toLowerCase()
          .replace(/[^a-z0-9]+/g, '-')
          .replace(/(^-|-$)/g, '')

        heading.id = id

        const li = document.createElement('li')
        const a = document.createElement('a')
        a.href = '#' + id
        a.textContent = heading.textContent
        a.className = 'toc-link'
        a.dataset.target = id
        li.appendChild(a)
        tocList.appendChild(li)
      })

      // Scroll spy - highlight active section
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              const id = entry.target.id
              document.querySelectorAll('.toc-link').forEach((link) => {
                link.classList.remove('active')
                if (link.dataset.target === id) {
                  link.classList.add('active')
                }
              })
            }
          })
        },
        {
          rootMargin: '-100px 0px -66%',
          threshold: 0,
        }
      )

      headings.forEach((heading) => observer.observe(heading))

      // Smooth scroll on TOC link click
      document.querySelectorAll('.toc-link').forEach((link) => {
        link.addEventListener('click', (e) => {
          e.preventDefault()
          const target = document.getElementById(link.dataset.target)
          if (target) {
            target.scrollIntoView({ behavior: 'smooth', block: 'start' })
            history.pushState(null, '', '#' + link.dataset.target)
          }
        })
      })
    }
  }
</script>
