---
import Layout from '../layouts/Layout.astro'

// Static page - no SSR needed
export const prerender = true

const interviews = [
  {
    name: 'Atomic Jolt',
    brandHref: 'https://atomicjoltmedia.com/episodes/episode-013-kylie-czajkowski-on-hiking',
    embedHref: 'https://open.spotify.com/embed/episode/2ETzCeYr5s1vQGSn7z1lJB',
    description:
      'A podcast that explores small moments of lasting impact. In this episode, Kylie discusses finding balance in life through hiking, the importance of unplugging to avoid burnout, triumphs and lessons learned from hiking Fourteeners, mountain goats, and more.',
  },
]
---

<Layout title="About" description="About Kylie and this site." ogImage="https://kylies.photos/open-graph/about.jpg">
  <div class="container page">
    <h1>About</h1>

    <div class="about-content">
      <section>
        <h2>Hey, I'm Kylie</h2>
        <p>
          I'm a software engineer based in Colorado who spends most of my free time in the mountains.
          This site is where I document my hikes, climbs, and adventures.
        </p>
        <p>
          I started hiking Colorado's peaks in 2019 and quickly became obsessed with the high alpine and learning about its terrain.
          What started as casual day hikes has evolved into longer backpacking trips, winter climbs,
          and the occasional scramble up something probably a bit too sketchy.
        </p>
      </section>

      <section>
        <h2>About This Site</h2>
        <p>
          This site is built with <a href="https://astro.build" target="_blank" rel="noopener">Astro</a>
          and runs on <a href="https://workers.cloudflare.com" target="_blank" rel="noopener">Cloudflare Workers</a>.
          Data is stored in <a href="https://developers.cloudflare.com/d1" target="_blank" rel="noopener">D1</a>
          (Cloudflare's SQLite database) and synced daily from my Notion databases.
        </p>
        <p>
          The source code is available on <a href="https://github.com/kale-stew/climb-log" target="_blank" rel="noopener">GitHub</a>.
        </p>
      </section>

      <section>
        <h2>Interviews</h2>
        <p class="section-subtitle">Kylie has appeared as a guest on...</p>
        <ul class="interviews-list">
          {interviews.map((interview) => (
            <li>
              <a href={interview.brandHref} target="_blank" rel="noopener">
                <strong>{interview.name}</strong>
              </a>
              {interview.description && `: ${interview.description}`}
              <iframe
                src={`${interview.embedHref}?utm_source=generator&theme=0`}
                width="100%"
                height="80"
                allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture"
                style="border: 0; border-radius: 12px; margin-top: 1rem;"
              />
            </li>
          ))}
        </ul>
      </section>

      <section>
        <h2>Get in Touch</h2>
        <p>
          Find me on <a href="https://github.com/kale-stew" target="_blank" rel="noopener">GitHub</a>,
          <a href="https://www.strava.com/athletes/46336787" target="_blank" rel="noopener">Strava</a>,
          or shoot me an email at <a href="mailto:hi@kylies.photos">hi@kylies.photos</a>.
        </p>
      </section>
    </div>
  </div>

  <style>
    .about-content {
      max-width: 700px;
    }

    .about-content section {
      margin-bottom: var(--space-2xl);
    }

    .about-content h2 {
      margin-bottom: var(--space-md);
    }

    .about-content p {
      line-height: 1.75;
      margin-bottom: var(--space-md);
    }

    .about-content a {
      text-decoration: underline;
      text-underline-offset: 2px;
    }

    .section-subtitle {
      font-style: italic;
      font-size: 0.9rem;
      color: var(--color-text-secondary);
    }

    .interviews-list {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .interviews-list li {
      margin-bottom: var(--space-xl);
    }

    .interviews-list li:last-child {
      margin-bottom: 0;
    }

    .interviews-list iframe {
      display: block;
    }
  </style>
</Layout>
