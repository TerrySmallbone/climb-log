---
import Layout from '../layouts/Layout.astro'
import ClimbTable from '../components/ClimbTable'
import { fillMissingPreviewImages } from '../lib/photo-fallbacks'
import { env } from 'cloudflare:workers'
import type { ClimbListItem } from '../lib/types'

export const prerender = false

const DB = env.DB

let climbs: ClimbListItem[] = []

if (DB) {
  try {
    // Fetch climbs with only the fields needed for the list view
    const result = await DB.prepare(
      'SELECT id, date, title, slug, preview_img_url, distance, gain, area, state, strava FROM climbs ORDER BY date DESC'
    ).all<ClimbListItem>()
    climbs = result.results || []

    // Fill missing preview images from photos table (200px thumbnails for table)
    await fillMissingPreviewImages(DB, climbs, 200)
  } catch (e) {
    console.error('Failed to fetch climbs:', e)
  }
}
---

<Layout title="Climb Log" description="A log of all my hikes and climbs." ogImage="https://kylies.photos/open-graph/climb-log.jpg">
  <div class="container page">
    <h1>Climb Log</h1>
    <p style="color: var(--color-text-secondary); margin-bottom: var(--space-xl);">
      A complete log of my hikes and climbs. Click on column headers to sort, use filters to narrow down.
    </p>

    <ClimbTable client:load climbs={climbs} />
  </div>
</Layout>
